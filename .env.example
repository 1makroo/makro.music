# Required: create a Discord application/bot at https://discord.com/developers/applications
DISCORD_TOKEN=discord-bot-token

# Leave blank to register slash commands globally, which can take time to appear.
DISCORD_GUILD_ID=

# Optional: required only for Spotify track/album/playlist links.
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: caps how many tracks can be queued from playlists/albums.
MAX_PLAYLIST_ITEMS=50
